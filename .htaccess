#######################################################################
#     Diese .htaccess wurde am 23.12.2024 erstellt      #
#######################################################################

# Fehlerseite 404 Weiterleitung
ErrorDocument 404 https://fewo-mainau.de/index.html

# Aktivierung von Komprimierung
<IfModule mod_gzip.c>
    mod_gzip_on Yes
</IfModule>

# HTTPS-Weiterleitung erzwingen
RewriteEngine on
RewriteCond %{HTTP_HOST} ^www\.fewo-mainau\.de [NC]
RewriteRule ^(.*)$ https://fewo-mainau.de/$1 [R=301,L]

# HTTP zu HTTPS f¸r alle Verbindungen erzwingen
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Dateikomprimierung aktivieren
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/shtml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript

    # Browser-Kompatibilit‰tsprobleme lˆsen
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# Caching f¸r bessere Leistung
<IfModule mod_headers.c>
    # Grafik-/Multimediadateien - 1 Jahr Cache
    <FilesMatch "\.(ico|jpg|jpeg|gif|png|ttf|svg|eot|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, no-transform"
    </FilesMatch>

    # Textdateien - 2 Stunden Cache
    <FilesMatch "\.(html|htm|xml|txt|xsl)$">
        Header set Cache-Control "public, max-age=7200, must-revalidate"
    </FilesMatch>

    # JavaScript und CSS - 1 Woche Cache
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800, must-revalidate"
    </FilesMatch>
</IfModule>

# Sicherheitseinstellungen
<IfModule mod_rewrite.c>
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*iframe.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*object.*(\>|%3E) [NC]
    RewriteRule .* - [F]
</IfModule>
